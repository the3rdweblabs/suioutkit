{
  "name": "suioutkit",
  "version": "1.0.1",
  "description": "Premium Universal Payment Gateway SDK for instant settlement on Sui",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=browser --format=esm --outfile=dist/index.js && tsc --emitDeclarationOnly --declaration",
    "build:types": "tsc --emitDeclarationOnly --declaration"
  },
  "keywords": [
    "sui",
    "payment",
    "fiat",
    "nigeria",
    "flutterwave",
    "stripe",
    "sdk"
  ],
  "author": "@CYBWithFlourish (https://github.com/CYBWithFlourish/)",
  "license": "GPL-3.0",
  "dependencies": {
    "@mysten/dapp-kit-core": "^1.3.2",
    "@mysten/payment-kit": "^0.1.11",
    "@mysten/sui": "^2.17.0",
    "@stripe/stripe-js": "^9.7.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
