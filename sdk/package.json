{
  "name": "suioutkit",
  "version": "1.2.1",
  "description": "Premium Universal Payment Gateway SDK for instant settlement on Sui",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=browser --format=esm --outfile=dist/index.js && tsc --emitDeclarationOnly --declaration",
    "build:types": "tsc --emitDeclarationOnly --declaration"
  },
  "keywords": [
    "sui",
    "payment",
    "fiat",
    "nigeria",
    "flutterwave",
    "stripe",
    "sdk"
  ],
  "author": "@CYBWithFlourish (https://github.com/CYBWithFlourish/)",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the3rdweblabs/suioutkit.git"
  },
  "homepage": "https://github.com/the3rdweblabs/suioutkit#readme",
  "bugs": {
    "url": "https://github.com/the3rdweblabs/suioutkit/issues"
  },
  "dependencies": {
    "@mysten/dapp-kit-core": "^1.6.1",
    "@mysten/payment-kit": "^0.2.1",
    "@mysten/sui": "^2.19.0",
    "@stripe/stripe-js": "^9.8.0",
    "lucide-react": "^1.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
