# SuiOutKit Environment Configuration
PORT=5000

# Redis - switch between local Docker and hosted (Upstash / Redis Cloud)
#   mode=local: uses REDIS_URL (default redis://localhost:6379)
#   mode=live:  uses REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, REDIS_TLS_ENABLED
REDIS_MODE=local
REDIS_URL=redis://localhost:6379
# REDIS_HOST=us1-xxxx.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password
# REDIS_TLS_ENABLED=true
# SESSION_TTL=86400

# FIAT PROVIDER: STRIPE
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Flutterwave API V3 (Charge Gateway)
FLW_API_BASE=https://api.flutterwave.com/v3
FLW_PUBLIC_KEY=your_flutterwave_public_key
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_HASH=your_webhook_secret_hash

# Decentralized Invoice Store (Walrus)
# publisher uses the public Walrus publisher; sdk signs/registers/certifies with WALRUS_OPERATOR_PRIVATE_KEY.
WALRUS_UPLOAD_MODE=publisher
WALRUS_EPOCHS=5
WALRUS_DELETABLE=false
WALRUS_USE_UPLOAD_RELAY=false
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.testnet.walrus.space
WALRUS_UPLOAD_RELAY_MAX_TIP=1000
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# Sui Ledger Connection
SUI_RPC_ENDPOINT=https://fullnode.testnet.sui.io:443
SUI_GRPC_ENDPOINT=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet

# Contract Object IDs (From Setup Bootstrap)
PACKAGE_ID=0x8c029c23e67a08bccec01c46dda9bb66a48eda8b72519dba3ca28504a4ddd507
TREASURY_ID=0x380ff0431c17c34147854eadd33422fb5d165817679fb37668f82b84ba64cf3e
FIAT_REGISTRY_ID=0x9023446c10d0db7a7ed50374cab5bd97859c6ff309c17d79067b376fb3533941
FIAT_REGISTRY_ADMIN_CAP_ID=0x65e7f127806c57ca8851fae687e8a2f68233cfba5d74e7cc3148d52f7c49e32a
FIAT_REGISTRY_NAME=suioutkit-fiat-settlements
CRYPTO_REGISTRY_ID=0xd08335554e2fb0e92dfce2707bd57195d7a21e80a1a0e8108e92fecf8da42ae8
CRYPTO_REGISTRY_NAME=suioutkit-crypto-settlements
CRYPTO_REGISTRY_ADMIN_CAP_ID=0x899b703d08f66c472fe8b609443cde2eedfa0b3e3b1d65be753a8698420224c3

# Operator Account Private Key (Ed25519 - Hex or Bech32 format)
SUI_OPERATOR_PRIVATE_KEY=
# Required when WALRUS_UPLOAD_MODE=sdk. Wallet must have SUI for gas and WAL for storage.
WALRUS_OPERATOR_PRIVATE_KEY=

# Settlement Payout parameters
SETTLEMENT_TOKEN_TYPE=0x2::sui::SUI
