# SuiOutKit Environment Configuration
PORT=5000

# Redis - three connection modes
#   mode=local: uses REDIS_URL directly (default redis://localhost:6379) - Docker Redis
#   mode=demo:  REDIS_HOST as URL, falls back to REDIS_URL - hosted single-URL (Railway, Upstash)
#   mode=live:  uses individual REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, REDIS_TLS_ENABLED
REDIS_MODE=local
REDIS_URL=redis://localhost:6379
# REDIS_HOST=us1-xxxx.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password
# REDIS_TLS_ENABLED=true
# SESSION_TTL=86400

# FIAT PROVIDER: STRIPE
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Flutterwave API V3 (Charge Gateway)
FLW_API_BASE=https://api.flutterwave.com/v3
FLW_PUBLIC_KEY=your_flutterwave_public_key
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_HASH=your_webhook_secret_hash

# Decentralized Invoice Store (Walrus) - network-specific URLs suffixed by SUI_NETWORK
# publisher uses the public Walrus publisher; sdk signs/registers/certifies with WALRUS_OPERATOR_PRIVATE_KEY.
WALRUS_UPLOAD_MODE=publisher
WALRUS_EPOCHS=5
WALRUS_DELETABLE=false
WALRUS_USE_UPLOAD_RELAY=false
WALRUS_UPLOAD_RELAY_URL_testnet=https://upload-relay.testnet.walrus.space
WALRUS_UPLOAD_RELAY_URL_mainnet=https://upload-relay.mainnet.walrus.space
WALRUS_UPLOAD_RELAY_MAX_TIP=1000
WALRUS_PUBLISHER_URL_testnet=https://publisher.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL_mainnet is not needed - mainnet uses SDK mode only

# Sui Ledger Connection - suffixed by SUI_NETWORK (testnet/mainnet)
SUI_NETWORK=testnet
SUI_RPC_ENDPOINT_testnet=https://fullnode.testnet.sui.io:443
SUI_RPC_ENDPOINT_mainnet=https://fullnode.mainnet.sui.io:443
SUI_GRPC_ENDPOINT_testnet=https://fullnode.testnet.sui.io:443
SUI_GRPC_ENDPOINT_mainnet=https://fullnode.mainnet.sui.io:443

# Contract Object IDs - suffixed by SUI_NETWORK (testnet/mainnet)
PACKAGE_ID_testnet=0x8c029c23e67a08bccec01c46dda9bb66a48eda8b72519dba3ca28504a4ddd507
PACKAGE_ID_mainnet=
PAYMENT_KIT_PACKAGE_ID_testnet=0x7e069abe383e80d32f2aec17b3793da82aabc8c2edf84abbf68dd7b719e71497
PAYMENT_KIT_PACKAGE_ID_mainnet=0xbc126f1535fba7d641cb9150ad9eae93b104972586ba20f3c60bfe0e53b69bc6
TREASURY_ID_testnet=0x380ff0431c17c34147854eadd33422fb5d165817679fb37668f82b84ba64cf3e
TREASURY_ID_mainnet=
FIAT_REGISTRY_ID_testnet=0x9023446c10d0db7a7ed50374cab5bd97859c6ff309c17d79067b376fb3533941
FIAT_REGISTRY_ID_mainnet=
FIAT_REGISTRY_ADMIN_CAP_ID_testnet=0x65e7f127806c57ca8851fae687e8a2f68233cfba5d74e7cc3148d52f7c49e32a
FIAT_REGISTRY_ADMIN_CAP_ID_mainnet=
CRYPTO_REGISTRY_NAME=suioutkit-crypto-settlements
CRYPTO_REGISTRY_ID_testnet=0xd08335554e2fb0e92dfce2707bd57195d7a21e80a1a0e8108e92fecf8da42ae8
CRYPTO_REGISTRY_ID_mainnet=
CRYPTO_REGISTRY_ADMIN_CAP_ID_testnet=0x899b703d08f66c472fe8b609443cde2eedfa0b3e3b1d65be753a8698420224c3
CRYPTO_REGISTRY_ADMIN_CAP_ID_mainnet=

# Operator Account Private Key (Ed25519 - Hex or Bech32 format)
SUI_OPERATOR_PRIVATE_KEY=
# Required when WALRUS_UPLOAD_MODE=sdk. Wallet must have SUI for gas and WAL for storage.
WALRUS_OPERATOR_PRIVATE_KEY=

# Settlement Payout parameters
# SUPPORTED_COINS is a JSON map of symbol->{type,coingeckoId,decimals}
# Defaults to SUI-only if not set or if SETTLEMENT_TOKEN_TYPE is set for backward compat.
# SUPPORTED_COINS='{"SUI":{"type":"0x2::sui::SUI","coingeckoId":"sui","decimals":9}}'
# DEFAULT_COIN=SUI
