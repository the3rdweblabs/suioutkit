{
  "name": "suioutkit-backend",
  "version": "1.0.0",
  "description": "Express Settle & Index Service for SuiOutKit",
  "main": "dist/index.js",
  "engines": {
    "node": ">=26.3.0"
  },
  "type": "module",
  "scripts": {
     "build": "tsc -p tsconfig.json",
    "start": "node --require ./crypto-polyfill.cjs dist/index.js",
    "dev": "tsc -w & nodemon dist/index.js",
    "treasury:balance": "node dist/scripts/treasury.js balance",
    "treasury:deposit": "node dist/scripts/treasury.js deposit",
    "treasury:withdraw": "node dist/scripts/treasury.js withdraw"
  },
  "keywords": [
    "sui",
    "fiat",
    "onramp",
    "flutterwave",
    "grpc"
  ],
  "author": "SuiOutKit Team",
  "license": "GPL-3.0",
  "dependencies": {
    "@mysten/payment-kit": "^0.2.1",
    "@mysten/sui": "^2.19.0",
    "@mysten/walrus": "^1.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "node-fetch": "^3.3.2",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3"
  }
}